# Supabase Configuration
# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Nera AI Chatbot API
# Supabase Edge Function URL for Nera conversations
VITE_NERA_API_URL=https://your-project.supabase.co/functions/v1/nera-query

# Pre-meeting Nera API (stakeholder engagement)
VITE_NERA_PREMEETING_API_URL=https://your-project.supabase.co/functions/v1/nera-premeeting

# Workshop AI API (facilitator assistant)
VITE_WORKSHOP_AI_API_URL=https://your-project.supabase.co/functions/v1/workshop-ai

# Workshop OCR API (photo text extraction)
VITE_WORKSHOP_OCR_API_URL=https://your-project.supabase.co/functions/v1/workshop-ocr

# Report Generation API
VITE_REPORT_API_URL=https://your-project.supabase.co/functions/v1/generate-report

# --- Edge Function Secrets (set via `supabase secrets set`) ---
# These are NOT used by the frontend. Set them as Supabase secrets.

# LLM API Keys — set the one matching your ai_config.llm_provider
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# OPENAI_API_KEY=sk-...

# Supabase Service Role Key (for server-side operations)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
