# Supabase Configuration
# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps API Key (Optional - only needed if using Map component)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Nera AI Chatbot API
# For Supabase Edge Function (recommended): https://your-project.supabase.co/functions/v1/nera-query
VITE_NERA_API_URL=https://your-project.supabase.co/functions/v1/nera-query

# n8n Webhook — Contact form + Layer 2 lead capture
# VITE_CONTACT_WEBHOOK_URL=https://your-n8n.railway.app/webhook/contact
# VITE_LAYER2_WEBHOOK_URL=https://your-n8n.railway.app/webhook/nera-layer2-lead

# --- Edge Function Secrets (set via `supabase secrets set`) ---
# These are NOT used by the frontend. Set them as Supabase secrets.

# LLM API Keys — set the one matching your ai_config.llm_provider
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# OPENAI_API_KEY=sk-...

# Client Configuration
# CLIENT_NAME=Your Organisation Name
# ADMIN_NOTIFICATION_EMAIL=admin@example.com
